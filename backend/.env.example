# Copy this file to `.env` in the same folder and fill in your real key.
# Never commit `.env` (it is listed in `.gitignore`).
#
# Get a key: https://aistudio.google.com/app/apikey

# Required: your Gemini API key (only used on the server — never in the browser)
GEMINI_API_KEY=

# Optional: main operations / public phone (e.g. “please call us at …”).
# Stops the model from writing placeholders like [Clinic Phone Number]. Example: 909-555-0100
# CLINIC_PUBLIC_PHONE=

# Optional: operations email for follow-up (e.g. billing or scheduling). Example: operations@clinic.example
# CLINIC_OPERATIONS_EMAIL=

# Optional: model id (see https://ai.google.dev/gemini-api/docs/models )
# Examples: gemini-2.5-flash, gemini-2.5-flash-lite, or a name from AI Studio docs
# Optional: max output tokens (default 8192). Raise if replies cut off mid-sentence.
# GEMINI_MAX_OUTPUT_TOKENS=8192

# Optional: thinking budget for models that support it. 0 = off (default, leaves more budget for the visible reply).
# Use "auto" or -1 for automatic. Integer = fixed budget in tokens.
# GEMINI_THINKING_BUDGET=0

# Optional: shared login for the web app (all staff use the same username/password).
# When all three are set, API routes require a Bearer token from POST /auth/login.
# APP_USERNAME=clinic
# APP_PASSWORD=choose-a-strong-password
# APP_SESSION_SECRET=generate-a-long-random-string-at-least-32-chars

# Supabase (recommended for production — persistent clinic knowledge + review library)
# Create a project at https://supabase.com → run backend/supabase/schema.sql in SQL Editor
# Project Settings → API: copy Project URL and service_role key (server only — never in the browser)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
